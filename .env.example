DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL (and each QWEN_*_MODEL override below) accepts a single model or
# a comma-separated fallback chain, e.g. QWEN_MODEL=qwen3.7-plus,qwen3.6-plus.
# Each model has its own free-tier quota; when one is exhausted mid-run, the
# client seamlessly switches to the next model in the chain instead of
# failing the call. A single value (no comma) behaves exactly as before.
QWEN_MODEL=qwen-plus
PORT=8787

# Orvix runtime API
# Set this on a public Alibaba Cloud deployment to require CLI requests to use
# Authorization: Bearer <token>. Leave empty for local development.
ORVIX_API_TOKEN=
# CLI default when connecting to a local or deployed Orvix API.
ORVIX_API_URL=http://localhost:8787

# Timeouts (ms)
QWEN_TIMEOUT_MS=240000
QWEN_ORVIX_MAP_TIMEOUT_MS=120000
QWEN_COMPACT_MAP_TIMEOUT_MS=60000
QWEN_MAP_REVIEW_TIMEOUT_MS=60000

# Scheduler concurrency
QWEN_EXECUTION_CONCURRENCY=unlimited
QWEN_REVISION_CONCURRENCY=unlimited
QWEN_REVIEW_CONCURRENCY=unlimited
# Total jobs (revision+signal+review+execution+build) the work-pool scheduler
# runs at once
QWEN_POOL_CONCURRENCY=unlimited
# How many fresh sessions MasterMind gives a blocked task before accepting
# it as blocked for good. The wake pass runs every scheduling round.
QWEN_BLOCKED_WAKE_LIMIT=2

# Qwen request behavior
QWEN_MAX_CONCURRENT_REQUESTS=unlimited
QWEN_ENABLE_THINKING=false
QWEN_THINKING_BUDGET=
# How long a model that reported "quota exhausted" is skipped in a fallback
# chain before Orvix tries it again (ms).
QWEN_MODEL_BENCH_MS=300000
# Per-agent stagger across a model fallback chain, so parallel agents don't
# all hammer the same model at once.
QWEN_SPREAD_AGENTS=true

# Optional per-role model overrides (fallback: QWEN_MODEL); each also accepts
# a comma-separated fallback chain
QWEN_PLANNER_MODEL=
QWEN_AGENT_MODEL=
QWEN_REVIEW_MODEL=

# Multi-turn agent sessions
QWEN_AGENT_MAX_TURNS=10
# Per-turn tool-call timeout (ms).
QWEN_AGENT_TURN_TIMEOUT_MS=120000
# Fallback context window (tokens) used only if the provider's /models
# endpoint doesn't return context-length metadata for the active model.
QWEN_CONTEXT_WINDOW_TOKENS=32768
# Compact session history once it crosses this percent of the model's
# context window.
QWEN_COMPACT_AT_PERCENT=80

# Orvix CLI
# Skip the first-run SetupWizard (useful for scripted demos).
ORVIX_SKIP_ONBOARDING=
# Disable mouse-tracking escape codes in the CLI — turn this on over a
# slow/high-latency SSH connection where mouse events flood the link.
ORVIX_MOUSE_TRACK=

# Solo baseline mode: one generalist agent owns the entire mission alone,
# so it needs a larger turn/tool-call budget than a specialist agent in
# society mode (used only when a mission runs with mode "solo")
QWEN_SOLO_AGENT_MAX_TURNS=40
QWEN_SOLO_AGENT_MAX_TOOL_CALLS=150
