flowchart TB
    User(["Owner / hackathon judge"])

    subgraph ClientSide["Client"]
        CLI["Orvix CLI (Ink/React TUI)\nSetupWizard -> LaunchPrompt -> Cockpit\nleft rail: brand, mission, phase, live repo tree\nSSE live feed + owner @mention prompt bar"]
    end

    subgraph AlibabaCloud["Alibaba Cloud"]
        subgraph ECS["ECS instance (Node.js runtime)"]
