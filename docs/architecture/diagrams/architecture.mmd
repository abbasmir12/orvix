                Planning["Planning pipeline\nresearch -> council -> scaffold\n-> Orvix Map -> org design"]
                Scheduler["Work-pool scheduler\nparallel revisions/reviews/executions\nMasterMind wake pass every round"]
                AgentRuntime["Agent runtime\nmulti-turn tool-use sessions"]
                Review["Critic Council review\n(branch file contents as ground truth)"]
                Acceptance["Runtime acceptance + incremental\nbuild gates (npm install/build,\nserialized per repo)"]
                Book["Orvix Book\nshared ledger + signals"]
                OwnerChannel["Owner channel\n@mention routing + hiring"]
                Brief["Mission debrief generator\n(versioned briefs)"]
            end
            Workspace[("Mission workspaces\n.orvix/workspaces/<id>/\nper-agent git worktrees + main")]
        end
    end

    subgraph ModelStudio["Qwen Cloud (Alibaba Cloud Model Studio / DashScope)"]
        QwenAPI["Qwen chat/completions\nnative tool-calls, JSON mode,\nmodel fallback chains, /models metadata"]
    end

